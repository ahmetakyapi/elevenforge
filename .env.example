# ───────────────────────────────────────────────────────────────
# ElevenForge env
# ───────────────────────────────────────────────────────────────

# next-auth v5 — required. Generate with: `openssl rand -base64 32`
AUTH_SECRET=""

# ───── Database ─────
# If unset, the app uses a local pglite file at ./data/pgdata (WASM Postgres).
# Set this to a Neon Postgres URL for production:
# DATABASE_URL="postgres://user:pass@host.neon.tech/db?sslmode=require"
# (Vercel's Neon integration will set this automatically.)
# DATABASE_URL=""

# Optional override for local pglite location
# PGLITE_DIR="./data/pgdata"

# ───── Cron (production) ─────
# A shared secret for /api/cron/* webhook endpoints. Generate with openssl.
# In dev mode this isn't required — cron endpoints are open.
# CRON_SECRET=""

# If using Upstash QStash to invoke cron endpoints, paste its keys here:
# QSTASH_TOKEN=""
# QSTASH_CURRENT_SIGNING_KEY=""
# QSTASH_NEXT_SIGNING_KEY=""

# ───── Web Push (production) ─────
# Generate a pair with: `npx web-push generate-vapid-keys`
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_SUBJECT="mailto:you@yourdomain.com"
